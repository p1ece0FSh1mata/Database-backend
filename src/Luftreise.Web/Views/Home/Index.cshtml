@{
    ViewData["Title"] = "Luftreise - Бронювання авіаквитків";
}

<div class="container">
    <div class="text-center py-5">
        <h1 class="display-4 mb-4">Вітаємо в Luftreise</h1>
        <p class="lead mb-4">Ваш надійний партнер у світі авіаперельотів</p>
        <a asp-controller="Flights" asp-action="Search" class="btn btn-primary btn-lg">Почати пошук рейсів</a>
    </div>

    <div class="row mt-5">
        <div class="col-md-4 text-center">
            <div class="card h-100">
                <div class="card-body">
                    <h3>Швидкий пошук</h3>
                    <p>Знайдіть найкращі рейси за лічені секунди</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 text-center">
            <div class="card h-100">
                <div class="card-body">
                    <h3>Безпечна оплата</h3>
                    <p>Захищені транзакції для вашого спокою</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 text-center">
            <div class="card h-100">
                <div class="card-body">
                    <h3>Підтримка 24/7</h3>
                    <p>Завжди готові допомогти вам</p>
                </div>
            </div>
        </div>
    </div>
</div>

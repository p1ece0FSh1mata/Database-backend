@{
    ViewData["Title"] = "Бронювання";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h2 class="card-title">Оформлення бронювання</h2>

                    <form asp-action="Create" method="post">
                        <input type="hidden" name="flightId" value="@ViewBag.FlightId" />

                        <div class="mb-3">
                            <label for="numberOfPassengers" class="form-label">Кількість пасажирів</label>
                            <input type="number" class="form-control" id="numberOfPassengers" name="numberOfPassengers" min="1" max="9" value="1" required />
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">Підтвердити бронювання</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
